<% layout('layouts/boilerplate') %>
    <div class="container text-center">
        <div class="col-10 offset-1 col-md-6 offset-md-3">


            <h1 class="text-dark m-3">
                Registra operazione
            </h1>

            <div class="row mt-5 g-2">

                <div>
                    <form action="/operations/visita" method="get">
                        <button class="btn btn-info w-100 py-4 fw-bold" type="submit">
                            Visita
                        </button>
                    </form>
                </div>

                <div>
                    <form action="/operations/cliente" method="get">
                        <button class="btn btn-info w-100 py-4 fw-bold" type="submit">
                            Cliente
                        </button>
                    </form>
                </div>

                <div>
                    <form action="/operations/interesse" method="get">
                        <button class="btn btn-info w-100 py-4 fw-bold" type="submit">
                            Interesse
                        </button>
                    </form>
                </div>

                <div>
                    <form action="/operations/ricerca" method="get">
                        <button class="btn btn-info w-100 py-4 fw-bold" type="submit">
                            Ricerca
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>