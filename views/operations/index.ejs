<% layout('layouts/boilerplate') %>

<main class="operations-page">
    <section class="operations-panel">

        <div class="operations-header">
            <h1 class="operations-title">Registra operazione</h1>
        </div>

        <div class="operations-list">

            <form action="/operations/visita" method="get">
                <button class="operation-btn" type="submit">
                    <span>Visita</span>
                    <span class="operation-arrow">→</span>
                </button>
            </form>

            <form action="/operations/cliente" method="get">
                <button class="operation-btn" type="submit">
                    <span>Cliente</span>
                    <span class="operation-arrow">→</span>
                </button>
            </form>

            <form action="/operations/interesse" method="get">
                <button class="operation-btn" type="submit">
                    <span>Interesse</span>
                    <span class="operation-arrow">→</span>
                </button>
            </form>

            <form action="/operations/ricerca" method="get">
                <button class="operation-btn" type="submit">
                    <span>Ricerca</span>
                    <span class="operation-arrow">→</span>
                </button>
            </form>

        </div>

    </section>
</main>